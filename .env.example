# ============================================================
# CARELY DEVICE CONFIGURATION
# ============================================================

# --- Device Identity ---
DEVICE_ID=carely-proto-001

# --- Network / Webhook ---
WEBHOOK_URL=http://192.168.1.100:5678/webhook/carely
WEBHOOK_TIMEOUT_S=0
WEBHOOK_MAX_RETRIES=0
WEBHOOK_RETRY_BACKOFF_MS=500
# Optional auth token for n8n:
WEBHOOK_AUTH_TOKEN=

# --- Audio Devices ---
# PipeWire device names (use `pw-cli list-objects Node` to find)
AUDIO_INPUT_DEVICE=default
AUDIO_OUTPUT_DEVICE=default

# --- VAD ---
VAD_AGGRESSIVENESS=3
VAD_PREROLL_MS=300
VAD_SPEECH_START_MS=30
VAD_SILENCE_END_MS=800
VAD_MIN_SPEECH_MS=500
VAD_MAX_UTTERANCE_MS=30000

# --- STT (whisper.cpp) ---
WHISPER_MODEL_PATH=/opt/assistant/models/whisper/ggml-base.bin
WHISPER_BINARY_PATH=/opt/assistant/bin/whisper-cli
WHISPER_THREADS=3
WHISPER_LANGUAGE=auto

# --- TTS (Piper) ---
PIPER_BINARY_PATH=/opt/assistant/bin/piper
PIPER_VOICE_EN=/opt/assistant/models/piper/en_US-lessac-medium.onnx
PIPER_VOICE_AR=/opt/assistant/models/piper/ar_JO-kareem-medium.onnx
PIPER_DEFAULT_VOICE=en

# --- Keyword Spotter ---
KEYWORD_SPOTTER_ENABLED=true
KEYWORD_SPOTTER_THRESHOLD=0.7

# --- Input ---
BUTTON_KEY=space
EMERGENCY_KEY=f12
LONG_PRESS_MS=1000

# --- UI ---
UI_HOST=0.0.0.0
UI_PORT=8080

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=/var/log/carely/carely.log

# --- System ---
HEALTH_PORT=8081
WATCHDOG_INTERVAL_S=15
CRASH_LOOP_THRESHOLD=5
CRASH_LOOP_WINDOW_S=300

# --- IPC ---
IPC_SOCKET_PATH=/run/carely/audio.sock
